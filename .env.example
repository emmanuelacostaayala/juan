# SMTP — outbound email (contact form, newsletter, admin codes)
# Use Zoho Mail credentials for marketing@juanandresromero.es
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=marketing@juanandresromero.es
SMTP_PASSWORD=

# Optional overrides
# SMTP_FROM="\"Juan Andrés Romero\" <marketing@juanandresromero.es>"
# CONTACT_TO=info@juanandresromero.es

# Postgres (newsletter subscribers + posts + admin login codes)
# Set this from Vercel → Storage → Neon Postgres → Connection string.
DATABASE_URL=

# Admin auth — login by email + 6-digit code. ADMIN_SECRET signs session cookies.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=
# Comma-separated list of emails allowed to log into /admin
ADMIN_EMAILS=marketing@juanandresromero.es
